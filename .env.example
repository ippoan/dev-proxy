# Copy to .env and adjust. Used by install.sh to render systemd units and
# by docker-compose.yml to resolve paths at compose time.
# DEV_PROXY_ROOT: where this repo is checked out (absolute path).
DEV_PROXY_ROOT=/home/yhonda/js/.dev-proxy

# DOCKER_BIN: path to docker (compose plugin required).
DOCKER_BIN=/usr/bin/docker

# NODE_BIN: path to node (trigger-agent is a pure mjs, node >= 20).
NODE_BIN=/usr/bin/node

# PROJECTS_ROOT: base dir for frontend checkouts referenced from projects.json.
# sync.yml (Phase 3) expands "${PROJECTS_ROOT}/<name>" for each entry's dir.
PROJECTS_ROOT=/home/yhonda/js

# Cloudflare (used by scripts/create-access-app.mjs + sync.yml)
CF_ACCOUNT_ID=
CF_TUNNEL_ID=
CF_API_TOKEN=
CF_ALLOW_EMAIL=
